{
  "expo": {
    "name": "RégieArt",
    "slug": "regiart",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "regiart",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.regiart.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.regiart.mobile"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ]
  }
}
